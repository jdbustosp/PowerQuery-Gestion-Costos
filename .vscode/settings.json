{
    // Forzar que los archivos .m NO sean tratados como Power Query por el linter.
    // Esto elimina TODOS los falsos positivos (rojo en explorador, subrayados, panel problemas).
    // La extensión de Power Query no tiene opción para desactivar solo los diagnósticos.
    "files.associations": {
        "*.m": "powerquery"
    },
    "powerquery.general.mode": "SDK"
}
